# ===========================================
# CCIP Validate Gate (script/ValidateCCIPPath.s.sol)
# ===========================================
# Profile:
# - auto: infer from chainid (currently base profile implemented)
# - base: use Base profile defaults
CCIP_VALIDATE_PROFILE=auto

# ===========================================
# Bridge token per-lane config (Phase 1 V2)
# script/SetBridgeTokenForDest.s.sol
# script/CheckBridgeTokenForDest.s.sol
# ===========================================
BRIDGE_TOKEN_GATEWAY=
BRIDGE_TOKEN_DEST_CAIP2=
BRIDGE_TOKEN_SOURCE_TOKEN=

# ===========================================
# Gateway V1 rollout status (Phase 5/6)
# script/SetGatewayV1Status.s.sol
# script/CheckGatewayV1Status.s.sol
# ===========================================
GATEWAY_V1_STATUS_GATEWAY=
# lane | global
GATEWAY_V1_STATUS_MODE=lane
GATEWAY_V1_STATUS_DEST_CAIP2=
GATEWAY_V1_STATUS_DISABLED=true

# ===========================================
# Gateway V2 readiness (Phase 7)
# script/ValidateGatewayV2Readiness.s.sol
# ===========================================
GW_VALIDATE_GATEWAY=
GW_VALIDATE_ROUTER=
GW_VALIDATE_DEST_CAIP2=
GW_VALIDATE_SOURCE_TOKEN=
GW_VALIDATE_DEST_TOKEN=
GW_VALIDATE_RECEIVER=
GW_VALIDATE_AMOUNT=100000
# optional (default 255 = use gateway default bridge)
GW_VALIDATE_BRIDGE_OPTION=255
# optional (empty => use lane bridge token mapping)
GW_VALIDATE_BRIDGE_TOKEN_SOURCE=
# optional (0 regular, 1 privacy)
GW_VALIDATE_MODE=0

