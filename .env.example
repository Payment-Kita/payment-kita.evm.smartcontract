ROUTE_CCIP_FEE_TOKEN=
# CCIP raw extraArgs (hex bytes, empty => sender default)
ROUTE_CCIP_EXTRA_ARGS_HEX=0x
# Optional destination-side CCIP receiver trust bootstrap
ROUTE_CCIP_RECEIVER=
ROUTE_CCIP_SOURCE_CHAIN_SELECTOR=0
# bytes-encoded source sender (e.g. abi.encode(sourceSenderAddress))
ROUTE_CCIP_TRUSTED_SENDER_HEX=0x
ROUTE_CCIP_ALLOW_SOURCE_CHAIN=true
ROUTE_LAYERZERO_ADAPTER=
ROUTE_LAYERZERO_DST_EID=0
ROUTE_LAYERZERO_PEER_BYTES32=
ROUTE_LAYERZERO_OPTIONS_HEX=0x

# ===========================================
# CCIP Adapter Rotation (script/RotateCCIPAdapters.s.sol)
# ===========================================
# Profile:
# - auto     : infer from chainid (8453 base / 137 polygon / 42161 arbitrum / 56 bsc)
# - base     : use Base defaults
# - polygon  : use Polygon defaults
# - arbitrum : use Arbitrum defaults
# - bsc      : use BSC profile (requires env addresses for router/gateway/vault)
CCIP_ROTATE_PROFILE=base

# Optional global overrides (all profiles)
# CCIP_ROTATE_CCIP_ROUTER=
# CCIP_ROTATE_ROUTER=
# CCIP_ROTATE_GATEWAY=
# CCIP_ROTATE_VAULT=
# CCIP_ROTATE_DEST_CAIP2=
