# CCIP_ROTATE_DEST_FEE_TOKEN=
# CCIP_ROTATE_SOURCE_SELECTOR=
# CCIP_ROTATE_SOURCE_TRUSTED_SENDER=
# CCIP_ROTATE_ALLOW_SOURCE_WHEN_TRUSTED_EMPTY=true
# CCIP_ROTATE_DEAUTHORIZE_OLD=false
# CCIP_ROTATE_SET_DEFAULT_BRIDGE=true
# CCIP_ROTATE_OLD_SENDER=
# CCIP_ROTATE_OLD_RECEIVER=

